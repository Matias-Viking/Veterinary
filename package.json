    "description": "Back-end para gestionar los clientes de una veterinaria",
    "main": "dist/app.js",
    "private": "true",
    "engines": {
        "node": ">=18"
    },
    "scripts": {
        "test": "vitest run --coverage",
        "dev": "npx kill-port 8080 && tsx watch src/app.ts",
